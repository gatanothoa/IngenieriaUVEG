# CONFIGURACIÓN DEL CHATBOT WHATSAPP - PLANTILLA UNIVERSAL 2.0
# Copia este archivo como .env y personaliza los valores

# Configuración del Bot
BOT_NAME=Mi ChatBot Assistant
BOT_VERSION=2.0.0

# Configuración de la Base de Datos
DB_MAX_MESSAGES=1000
AUTO_BACKUP=true
BACKUP_INTERVAL_HOURS=24

# Configuración de Logging
LOG_LEVEL=info
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
MAX_LOG_FILE_SIZE=10485760
MAX_LOG_FILES=10

# Configuración del Panel Web (NUEVO)
WEB_PORT=3000
ENABLE_WEB_PANEL=true

# Configuración de APIs (opcional)
# OPENWEATHER_API_KEY=tu_api_key_aqui
# GEMINI_API_KEY=tu_api_key_aqui

# Configuración de Seguridad
ADMIN_NUMBERS=
MAX_MESSAGES_PER_MINUTE=10

# Configuración de Respuestas
RESPONSE_DELAY_MIN=1000
RESPONSE_DELAY_MAX=3000

# ========================================
# CONFIGURACIÓN DE EMPRESA - PERSONALIZAR
# ========================================

# Información de la Empresa
COMPANY_NAME=Nombre de tu Empresa
COMPANY_PHONE=+52XXXXXXXXXX
COMPANY_EMAIL=contacto@tuempresa.com
COMPANY_WEBSITE=https://tuempresa.com
COMPANY_ADDRESS=Ciudad, País

# Productos/Servicios (separados por comas)
COMPANY_PRODUCTS=Producto 1,Producto 2,Producto 3
COMPANY_SERVICES=Servicio 1,Servicio 2,Servicio 3

# Horarios de Atención
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00
BUSINESS_DAYS=Lunes a Viernes

# WhatsApp Business
WHATSAPP_BUSINESS_NUMBER=+52XXXXXXXXXX
WHATSAPP_GROUP_SUPPORT=

# Redes Sociales (opcional)
FACEBOOK_URL=
INSTAGRAM_URL=
LINKEDIN_URL=
TWITTER_URL=
